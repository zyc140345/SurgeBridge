AIRPORT_SUBSCRIPTION_URL="https://example.com/path/to/your/clash-subscription"
PORT=3000
SURGIO_PUBLIC_URL="http://localhost:3000/get-artifact/"
SURGIO_GATEWAY_AUTH=true
SURGIO_ACCESS_TOKEN="change-this-token"
# Optional: read-only token for browsing the panel and calling download APIs
# SURGIO_VIEWER_TOKEN="change-this-viewer-token"
# Surgio's memory cache cannot be disabled with a native "none" mode.
# Use a near-zero TTL instead. Do not set these to 0, because 0 means "no TTL tracking".
SURGIO_PROVIDER_CACHE_MAXAGE=1
SURGIO_REMOTE_SNIPPET_CACHE_MAXAGE=1
SINGBOX_SOCKS_BASE_PORT=41000
# Optional: set SINGBOX_DNS_STRATEGY to prefer_ipv4 / prefer_ipv6 / ipv4_only / ipv6_only
SINGBOX_DNS_PRIMARY=dns.alidns.com
SINGBOX_DNS_PRIMARY_SERVER_NAME=dns.alidns.com
SINGBOX_DNS_SECONDARY=doh.pub
SINGBOX_DNS_SECONDARY_SERVER_NAME=doh.pub
SINGBOX_DNS_BOOTSTRAP_PRIMARY=223.5.5.5
SINGBOX_DNS_BOOTSTRAP_SECONDARY=119.29.29.29
